generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite + a checked-in seed (see prisma/seed.mjs, sourced from
// src/mock/data.json) so this app has a real, queryable local database
// without standing up an external Postgres/MySQL instance.

model Tenant {
  id        String   @id
  name      String
  subdomain String   @unique
  plan      String
  status    String
  createdAt DateTime @map("created_at")
  settings  Json

  users     User[]
  documents Document[]
  auditLogs AuditLog[]

  @@map("tenants")
}

model User {
  id            String  @id
  email         String  @unique
  passwordHash  String  @map("password_hash")
  role          String
  clearance     Int
  department    String
  mfaVerified   Boolean @map("mfa_verified")
  accountLocked Boolean @map("account_locked")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  documents Document[]
  auditLogs AuditLog[]

  @@index([tenantId])
  @@map("users")
}

model Document {
  id                String   @id @default(uuid())
  title             String
  department        String?
  clearanceRequired Int      @default(1) @map("clearance_required")
  createdAt         DateTime @default(now()) @map("created_at")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  ownerId String @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [id])

  @@index([tenantId])
  @@map("documents")
}

model AuditLog {
  id           String   @id
  timestamp    DateTime
  subjectEmail String   @map("subject_email")
  action       String
  resource     String
  outcome      String
  reason       String
  ipAddress    String   @map("ip_address")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  subjectId String? @map("subject_id")
  subject   User?   @relation(fields: [subjectId], references: [id])

  @@index([tenantId])
  @@map("audit_logs")
}
